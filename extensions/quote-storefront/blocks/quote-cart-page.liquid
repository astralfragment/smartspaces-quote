{% comment %}
  Section block intended for /pages/request-quote. Renders cart summary + form.
  Form is submitted via JS to the App Proxy (/apps/quote/submit).
{% endcomment %}

{%- assign settings_json = shop.metafields.quote.settings.value -%}

<section class="qr-request-page" data-qr-request-page
         data-logged-in-customer-id="{{ customer.id | default: '' }}">
  <h1>{{ block.settings.heading | default: 'Request a Quote' }}</h1>
  <p class="qr-intro">{{ block.settings.intro | default: 'Tell us about your project and we’ll get back with a tailored estimate.' }}</p>

  <div class="qr-layout">
    <div class="qr-summary" data-qr-summary>
      <h2>Items in your quote</h2>
      <ul data-qr-summary-items></ul>
      <p class="qr-empty" data-qr-summary-empty hidden>Your quote is empty — browse the shop to add items.</p>
    </div>

    <form class="qr-form" data-qr-form novalidate>
      <label>
        Name *
        <input required type="text" name="contact_name" autocomplete="name" />
      </label>
      <label>
        Email *
        <input required type="email" name="contact_email" autocomplete="email" />
      </label>
      {% if settings_json == blank or settings_json contains 'collectPhone":true' %}
        <label>
          Phone
          <input type="tel" name="contact_phone" autocomplete="tel" />
        </label>
      {% endif %}
      {% if settings_json == blank or settings_json contains 'collectProjectAddress":true' %}
        <label>
          Project address
          <textarea name="project_address" rows="2"></textarea>
        </label>
      {% endif %}
      {% if settings_json == blank or settings_json contains 'collectTimeline":true' %}
        <label>
          Timeline
          <input type="text" name="timeline" placeholder="e.g. next 3 months" />
        </label>
      {% endif %}
      {% if settings_json contains 'collectBudgetRange":true' %}
        <label>
          Budget range
          <input type="text" name="budget_range" placeholder="e.g. $20k–$50k" />
        </label>
      {% endif %}
      <label>
        Project details
        <textarea name="notes" rows="4" placeholder="Rooms, zones, existing systems, integrations, etc."></textarea>
      </label>
      {% if settings_json == blank or settings_json contains 'collectFloorPlan":true' %}
        <label>
          Floor plan (optional — PDF or image, max 10 MB)
          <input type="file" name="floor_plan" accept=".pdf,image/*" />
        </label>
      {% endif %}

      {% comment %} Honeypot — real users never fill this. {% endcomment %}
      <input type="text" name="honeypot" tabindex="-1" autocomplete="off"
             style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0" aria-hidden="true" />

      <button type="submit" class="qr-btn qr-btn--primary" data-qr-submit>
        {{ block.settings.submit_text | default: 'Submit Quote Request' }}
      </button>
      <p class="qr-status" data-qr-status role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "Quote: Request Page",
  "target": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Request a Quote" },
    { "type": "textarea", "id": "intro", "label": "Intro text", "default": "Tell us about your project and we’ll get back with a tailored estimate." },
    { "type": "text", "id": "submit_text", "label": "Submit button text", "default": "Submit Quote Request" }
  ]
}
{% endschema %}
