{% comment %}
  Product page block for quote-only products.

  Does NOT render a new button. Instead:
    - Hides the native price element (optional, per shop settings).
    - Relabels the existing native Add-to-Cart button with the configured CTA.

  Quote-only detection: product tag match OR quote.quote_only metafield.
  Settings pulled from shop.metafields.quote.settings with safe defaults.
{% endcomment %}

{%- liquid
  assign raw_settings = shop.metafields.quote.settings.value

  assign default_tag = 'quote-only'
  assign default_add = 'Add to Quote'
  assign default_req = 'Request Quote'

  if raw_settings == blank
    assign quote_tag = default_tag
    assign cta_add = default_add
    assign cta_req = default_req
    assign hide_price_pdp = true
    assign hide_price_col = true
  else
    assign s = raw_settings
    assign quote_tag = s.quoteOnlyTag | default: default_tag
    assign cta_add = s.ctaAddToQuote | default: default_add
    assign cta_req = s.ctaRequestQuote | default: default_req
    assign hide_price_pdp = s.hidePriceOnPDP
    if hide_price_pdp == nil
      assign hide_price_pdp = true
    endif
    assign hide_price_col = s.hidePriceOnCollection
    if hide_price_col == nil
      assign hide_price_col = true
    endif
  endif

  assign is_quote_only = false
  if product.metafields.quote.quote_only
    assign is_quote_only = true
  endif
  if product.tags contains quote_tag
    assign is_quote_only = true
  endif
-%}

{%- if is_quote_only -%}
  {%- if hide_price_pdp -%}
    <style>
      #MainProduct-{{ section.id }} .price,
      #MainProduct-{{ section.id }} .product__price,
      #MainProduct-{{ section.id }} [data-product-price],
      #shopify-section-{{ section.id }} .price,
      #shopify-section-{{ section.id }} .product__price,
      #shopify-section-{{ section.id }} [data-product-price] {
        display: none !important;
      }
    </style>
  {%- endif -%}

  <script>
    (function () {
      var SECTION_ID = {{ section.id | json }};
      var CTA_TEXT = {{ cta_add | json }};

      function relabel() {
        var scope =
          document.getElementById('MainProduct-' + SECTION_ID) ||
          document.getElementById('shopify-section-' + SECTION_ID) ||
          document;

        var selectors = [
          '.product-form__submit',
          'button[name="add"]',
          '[data-add-to-cart]',
        ];

        var seen = new Set();
        selectors.forEach(function (sel) {
          var nodes = scope.querySelectorAll(sel);
          nodes.forEach(function (btn) {
            if (seen.has(btn)) return;
            seen.add(btn);
            // Prefer a dedicated text span if the theme uses one;
            // otherwise swap the button's direct text nodes.
            var textSpan = btn.querySelector('span:not([class*="icon"]):not([hidden])');
            if (textSpan && textSpan.childNodes.length) {
              textSpan.textContent = CTA_TEXT;
            } else {
              // Walk direct child text nodes and replace the first non-empty one.
              var replaced = false;
              for (var i = 0; i < btn.childNodes.length; i++) {
                var n = btn.childNodes[i];
                if (n.nodeType === 3 && n.textContent.trim().length > 0) {
                  n.textContent = CTA_TEXT;
                  replaced = true;
                  break;
                }
              }
              if (!replaced) {
                btn.textContent = CTA_TEXT;
              }
            }
            btn.setAttribute('data-qr-relabeled', 'true');
          });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', relabel);
      } else {
        relabel();
      }
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Quote: Product CTA",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "quote_page_handle",
      "label": "Quote page handle",
      "default": "request-quote"
    }
  ]
}
{% endschema %}
